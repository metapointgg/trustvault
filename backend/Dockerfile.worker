FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src

WORKDIR /app

COPY pyproject.toml ./
COPY alembic.ini ./
COPY migrations ./migrations
COPY src ./src
COPY config ./config

RUN pip install --upgrade pip && pip install -e ".[dev,cloud]"

CMD ["python", "-m", "trustvault.worker.main"]
