FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src

WORKDIR /app

COPY pyproject.toml ./
COPY alembic.ini ./
COPY migrations ./migrations
COPY src ./src
COPY config ./config

RUN pip install --upgrade pip && pip install -e ".[dev,cloud]"

CMD ["uvicorn", "trustvault.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
