TRUSTVAULT_ENVIRONMENT=local
TRUSTVAULT_APP_NAME=TrustVault
TRUSTVAULT_DATABASE_URL=postgresql+psycopg://trustvault:trustvault_dev_password@postgres:5432/trustvault
TRUSTVAULT_STORAGE_PROVIDER=local
TRUSTVAULT_LOCAL_STORAGE_ROOT=/app/local-data/storage
TRUSTVAULT_QUEUE_PROVIDER=local
TRUSTVAULT_LICENCE_FILE=/app/config/licence.example.json
TRUSTVAULT_LICENCE_PUBLIC_KEY_FILE=/app/config/licence_public_key.pem
TRUSTVAULT_AI_PROVIDER=none
TRUSTVAULT_OCR_PROVIDER=none
TRUSTVAULT_AUDIT_ENABLED=true
TRUSTVAULT_AUTH_MODE=local
TRUSTVAULT_AUTH_REQUIRED=true
TRUSTVAULT_AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
TRUSTVAULT_AUTH_TOKEN_TTL_MINUTES=480
TRUSTVAULT_LOCAL_ADMIN_EMAIL=admin@trustvault.local
TRUSTVAULT_LOCAL_ADMIN_DISPLAY_NAME=TrustVault Administrator
# Set this only for initial local bootstrap, then rotate/remove it after first login.
TRUSTVAULT_LOCAL_ADMIN_PASSWORD=
